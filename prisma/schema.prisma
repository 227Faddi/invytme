generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model RSVP {
  id          String       @id @default(cuid())
  name        String
  attending   Boolean
  dietary     String?
  message     String?
  createdAt   DateTime     @default(now())
  extraGuests ExtraGuest[]
}

model ExtraGuest {
  id      String  @id @default(cuid())
  name    String
  dietary String?
  rsvpId  String
  rsvp    RSVP    @relation(fields: [rsvpId], references: [id], onDelete: Cascade)
}
